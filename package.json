{
  "name": "eslint-plugin-no-unconsumed-fetch",
  "version": "1.0.0",
  "description": "ESLint rule to flag fetch() calls whose response body is not consumed or cancelled",
  "main": "dist/src/index.js",
  "types": "dist/src/index.d.ts",
  "files": [
    "dist/src"
  ],
  "scripts": {
    "build": "tsc",
    "test": "tsx tests/rules/no-unconsumed-fetch.test.ts",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "format": "oxfmt",
    "format:check": "oxfmt --check",
    "prepublishOnly": "npm run build"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/gu-stav/no-unconsumed-fetch.git"
  },
  "keywords": [
    "eslint",
    "eslintplugin",
    "fetch",
    "response",
    "body",
    "consume"
  ],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "peerDependencies": {
    "eslint": ">=8.40.0"
  },
  "bugs": {
    "url": "https://github.com/gu-stav/no-unconsumed-fetch/issues"
  },
  "homepage": "https://github.com/gu-stav/no-unconsumed-fetch#readme",
  "devDependencies": {
    "@types/eslint": "^9.6.1",
    "eslint": "^10.2.0",
    "oxfmt": "^0.45.0",
    "oxlint": "^1.60.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2"
  }
}
