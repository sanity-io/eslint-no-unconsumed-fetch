{
  "name": "no-unconsumed-fetch",
  "version": "1.0.0-alpha.2",
  "description": "ESLint rule to flag fetch() calls whose response body is not consumed or cancelled",
  "keywords": [
    "body",
    "consume",
    "eslint",
    "eslintplugin",
    "fetch",
    "response"
  ],
  "homepage": "https://github.com/gu-stav/no-unconsumed-fetch#readme",
  "bugs": {
    "url": "https://github.com/gu-stav/no-unconsumed-fetch/issues"
  },
  "license": "MIT",
  "author": "",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/gu-stav/no-unconsumed-fetch.git"
  },
  "files": [
    "dist/src"
  ],
  "type": "commonjs",
  "main": "dist/src/index.js",
  "types": "dist/src/index.d.ts",
  "scripts": {
    "build": "tsc",
    "test": "tsx tests/rules/no-unconsumed-fetch.test.ts",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "format": "oxfmt",
    "format:check": "oxfmt --check",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "pnpm run build && changeset publish",
    "prepublishOnly": "pnpm run build"
  },
  "devDependencies": {
    "@changesets/changelog-github": "^0.6.0",
    "@changesets/cli": "^2.31.0",
    "@types/eslint": "^9.6.1",
    "@types/estree": "^1.0.8",
    "@typescript-eslint/parser": "^8.58.2",
    "eslint": "^10.2.0",
    "oxfmt": "^0.45.0",
    "oxlint": "^1.60.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2"
  },
  "peerDependencies": {
    "eslint": ">=8.40.0"
  },
  "engines": {
    "node": ">=20"
  },
  "packageManager": "pnpm@10.33.0",
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  }
}
